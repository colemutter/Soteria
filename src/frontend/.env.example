# Copy to `.env` and fill in. Vite only reads these at server start, so restart
# the dev server after changing them.

# Supabase project (used by the read-only frontend data features: space-weather
# charts, solar-wind / geomag layers).
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Soteria backend API base URL. REQUIRED for adding and restoring satellites —
# they persist through the backend (`POST/GET /api/satellites`), not Supabase
# directly. Without this, satellite sync + restore-on-reload silently no-op.
# Must match the port the backend (src/backend) runs on, e.g. 8000.
VITE_API_BASE_URL=http://localhost:8001
